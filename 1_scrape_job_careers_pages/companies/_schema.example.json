{
  "_comment": "Copy to companies/<company>.json — all scraping rules live here; Python code stays generic.",

  "companyName": "Example Company",
  "careerUrl": "https://careers.example.com/jobs",
  "enabled": true,
  "crawlFrequencyHours": 24,
  "defaultLocation": "",

  "steps": [
    { "action": "open_url" },
    {
      "action": "dismiss_overlays",
      "selectors": [
        "#onetrust-accept-btn-handler",
        "button:has-text('Accept')"
      ]
    }
  ],

  "filters": [
    {
      "id": "location",
      "label": "Location",
      "action": "autocomplete",
      "openSelector": "button:has-text('Location')",
      "inputSelector": "#location-input",
      "value": "India",
      "optionText": "India",
      "optionSelector": "[role='option']:has-text('India')",
      "waitMs": 800,
      "optional": false
    },
    {
      "id": "country",
      "label": "Country checkbox",
      "action": "checkbox",
      "openSelector": "#country-toggle",
      "checkboxSelector": "#country-filter-18",
      "ensureChecked": true,
      "optional": false
    },
    {
      "id": "sortBy",
      "label": "Sort by date posted",
      "action": "select",
      "selector": "select[data-search-results-sort-enhanced='true']",
      "value": "1",
      "matchBy": "value",
      "optional": true
    }
  ],

  "scrapeOptions": {
    "maxPages": 2,
    "waitAfterFiltersMs": 2000,
    "scrollBeforeExtract": true,
    "waitForResultsSelector": "li.sr-job-item, a[href*='/job/']"
  },

  "jobLinkStrategy": {
    "_strategyTypes": ["direct_extract", "card_extract", "hover_and_extract"],

    "type": "card_extract",
    "cardSelector": "li.sr-job-item",
    "linkSelector": "a.sr-job-item__link",
    "fields": {
      "location": "span.sr-job-location",
      "jobType": "span.sr-job-type"
    },
    "jobId": {
      "_sources": ["url", "attribute", "attribute_first", "url_first"],
      "source": "attribute_first",
      "attribute": "data-job-id",
      "attributeScope": "link",
      "urlPattern": "/(\\d+)$"
    }
  },

  "pagination": {
    "_types": ["next_button", "page_jump"],
    "type": "page_jump",
    "inputSelector": "#pagination-current-bottom",
    "goButtonSelector": "button.pagination-page-jump"
  }
}
