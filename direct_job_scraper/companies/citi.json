{
  "companyName": "Citi",
  "careerUrl": "https://jobs.citi.com/search-jobs",
  "enabled": true,
  "crawlFrequencyHours": 24,
  "defaultLocation": "India",

  "steps": [
    { "action": "open_url" },
    { "action": "dismiss_cookies" }
  ],

  "filters": [
    {
      "id": "country",
      "label": "Country - India",
      "action": "checkbox",
      "openSelector": "#country-toggle",
      "checkboxSelector": "#country-filter-18",
      "ensureChecked": true,
      "optional": false
    },
    {
      "id": "sortBy",
      "label": "Sort by Date Posted",
      "action": "select",
      "selector": "select[data-search-results-sort-enhanced='true']",
      "value": "1",
      "matchBy": "value",
      "optional": false
    }
  ],

  "scrapeOptions": {
    "maxPages": 2,
    "waitAfterFiltersMs": 3000,
    "scrollBeforeExtract": true,
    "waitForResultsSelector": "li.sr-job-item"
  },

  "jobLinkStrategy": {
    "type": "card_extract",
    "cardSelector": "li.sr-job-item",
    "linkSelector": "a.sr-job-item__link",
    "fields": {
      "location": "span.sr-job-location",
      "jobType": "span.sr-job-type"
    },
    "jobId": {
      "source": "attribute_first",
      "attribute": "data-job-id",
      "attributeScope": "link",
      "urlPattern": "/(\\d+)$"
    }
  },

  "pagination": {
    "type": "page_jump",
    "inputSelector": "#pagination-current-bottom",
    "goButtonSelector": "button.pagination-page-jump"
  }
}
